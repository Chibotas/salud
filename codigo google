function doPost(e) {
var hoja = SpreadsheetApp .getActiveSpreadsheet().
getActiveSheet();
var datos = JSON.parse(e.postData.contents);

 hoja.appendRow([
datos.nombre,
datos.edad,
datos.fecha,

 ]);

 return ContentService.createTextOutput("OK");

}

